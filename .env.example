# این فایل را کپی کنید به نام .env و مقادیر واقعی را وارد کنید.
# فایل .env هرگز نباید روی گیت‌هاب یا جای عمومی آپلود شود.

# توکن ربات تلگرام (از @BotFather)
TOKEN=

# آیدی عددی ادمین (از @userinfobot)
ADMIN_ID=

# شماره کارت برای دریافت شارژ کیف پول
CARD_NUMBER=6219861881813637
CARD_HOLDER=امین نجفی

# مسیر فایل دیتابیس (اختیاری - پیش‌فرض database.db)
DATABASE_PATH=database.db

# مبلغی که با ثبت‌نام هر فرد دعوت‌شده، به‌صورت قفل به معرف تعلق می‌گیرد
REFERRAL_LOCK_AMOUNT=40000

# یوزرنیم ربات بدون @ (برای ساخت لینک دعوت)
BOT_USERNAME=BusinessSVPNBot

# کلید رمزنگاری کانفیگ‌ها (در مرحله بعد تولید و اینجا قرار می‌گیرد)
CONFIG_ENCRYPTION_KEY=
